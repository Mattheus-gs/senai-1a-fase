programa
{
	
	funcao inicio()
	{
		real Racao, RacaoKg, Valor
		

		escreva("quantos gramas de ração voce quer comprar? ")
		leia (Racao)

		RacaoKg = Racao/1000

		Valor= RacaoKg*10

		escreva("O seu pedido deu R$ " + Valor)

		
		
	}
}
